<Window x:Class="SportFederationsAccounting.WPF.FederationEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование федерации"
        Height="610"
        Width="880"
        MinWidth="880"
        MinHeight="610"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid Margin="30">
        <StackPanel>
            <!-- Код и Короткое наименование -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,15" >
                <StackPanel Width="180">
                    <TextBlock Text="Код" FontSize="14" Margin="0,0,0,5"/>
                    <TextBox x:Name="tbCode" IsReadOnly="True" Background="#F0F0F0" Height="32"
                             VerticalContentAlignment="Center"/>
                </StackPanel>
                <StackPanel Margin="20,0,0,0" Width="580">
                    <TextBlock Text="Короткое наименование" FontSize="14" Margin="0,0,0,5"/>
                    <TextBox x:Name="tbShortName" Height="32"
                             VerticalContentAlignment="Center"/>
                </StackPanel>
            </StackPanel>

            <!-- Полное наименование -->
            <TextBlock Text="Полное наименование *" FontSize="14" Margin="0,0,0,5"/>
            <TextBox x:Name="tbFullName" Height="32" Margin="0,0,0,15" VerticalContentAlignment="Center"/>

            <!-- Вид спорта -->
            <StackPanel Margin="0,8">
                <TextBlock Text="Вид спорта *" FontSize="14" Margin="0,0,0,5"/>
                <StackPanel Orientation="Horizontal" >
                    <ComboBox x:Name="cbSportType" Width="280" Height="32" Margin="0,0,10,0" VerticalContentAlignment="Center"/>
                    <Button Content="📋 Выбрать из справочника" Height="32" Padding="12,0" />
                </StackPanel>
            </StackPanel>

            <!-- Статус аккредитации и Состояние -->
            <StackPanel Orientation="Horizontal" Margin="0,12">
                <StackPanel Width="390">
                    <TextBlock Text="Статус аккредитации *" FontSize="14" Margin="0,0,0,5"/>
                    <ComboBox x:Name="cbAccreditationStatus" Height="32" VerticalContentAlignment="Center"/>
                </StackPanel>
                <StackPanel Margin="20,0,0,0" Width="390">
                    <TextBlock Text="Состояние федерации *" FontSize="14" Margin="0,0,0,5"/>
                    <ComboBox x:Name="cbFederationState" Height="32" VerticalContentAlignment="Center"/>
                </StackPanel>
            </StackPanel>

            <!-- Контактная информация -->
            <TextBlock Text="Контактная информация" FontSize="14" FontWeight="Medium" Margin="0,20,0,8"/>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <StackPanel Width="390">
                    <TextBlock Text="Юридический адрес" FontSize="14" Margin="0,0,0,5"/>
                    <TextBox x:Name="tbLegalAddress" Height="32" VerticalContentAlignment="Center"/>
                </StackPanel>
                <StackPanel Margin="20,0,0,0" Width="390">
                    <TextBlock Text="Почтовый адрес" FontSize="14" Margin="0,0,0,5"/>
                    <TextBox x:Name="tbPostalAddress" Height="32" VerticalContentAlignment="Center"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <StackPanel Width="390">
                    <TextBlock Text="Телефон" FontSize="14" Margin="0,0,0,5"/>
                    <TextBox x:Name="tbPhone" Height="32" VerticalContentAlignment="Center"/>
                </StackPanel>
                <StackPanel Margin="20,0,0,0" Width="390">
                    <TextBlock Text="E-mail" FontSize="14" Margin="0,0,0,5"/>
                    <TextBox x:Name="tbEmail" Height="32" VerticalContentAlignment="Center"/>
                </StackPanel>
            </StackPanel>

            <!-- Кнопки -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                <Button Content="Отмена" 
                        Width="130" 
                        Height="36" 
                        Margin="0,0,12,0"
                        Click="BtnCancel_Click"/>
                <Button Content="Сохранить изменения" 
                        Width="190" 
                        Height="36"
                        Click="BtnSave_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>