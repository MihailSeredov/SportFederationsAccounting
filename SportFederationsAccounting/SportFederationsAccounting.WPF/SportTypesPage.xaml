<Window x:Class="SportFederationsAccounting.WPF.SportTypesPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Виды спорта"
        Height="670"
        MinHeight="670"
        Width="600"
        MinWidth="600"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>


        <!-- Стиль для кнопок -->
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#263248"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Height" Value="72"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#BEE6FD"/>
                    <Setter Property="Foreground" Value="#263248"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        

        <!-- Заголовок -->
        <TextBlock Text="Виды спорта" 
                   FontSize="24" 
                   FontWeight="SemiBold"
                   Margin="0,0,0,20"/>

        <!-- Таблица -->
        <DataGrid x:Name="dgSportTypes" 
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  IsReadOnly="False"
                  CanUserAddRows="False"
                  MouseDoubleClick="dgSportTypes_MouseDoubleClick"
                  Margin="0,0,0,20">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Название" 
                                    Binding="{Binding Name}" 
                                    Width="*" 
                                    IsReadOnly="False">
                    <DataGridTextColumn.HeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="FontSize" Value="16"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="8,6"/>
                        </Style>
                    </DataGridTextColumn.HeaderStyle>
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontSize" Value="15"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Кнопки внизу -->
        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right">

            <Button Content="Добавить новый вид спорта" 
                    Width="220"
                    Height="40"
                    Margin="0,0,12,0"
                    Click="BtnAddNew_Click"
                    Style="{StaticResource MenuButtonStyle}"/>

            <Button x:Name="BtnSelect"
                    Content="Выбрать" 
                    Width="130" 
                    Height="40" 
                    Margin="0,0,12,0"
                    Click="BtnSelect_Click"
                    Style="{StaticResource MenuButtonStyle}"/>

            <Button Content="Отмена" 
                    Width="110" 
                    Height="40"
                    Click="BtnCancel_Click"
                    Style="{StaticResource MenuButtonStyle}"/>
        </StackPanel>
    </Grid>
</Window>