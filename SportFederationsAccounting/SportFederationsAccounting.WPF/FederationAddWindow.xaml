<Window x:Class="SportFederationsAccounting.WPF.FederationAddWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Карточка федерации" 
        Height="960" 
        Width="960"
        WindowStartupLocation="CenterScreen"
        Background="#F8F9FA"
        ResizeMode="NoResize">

    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Text="Карточка федерации" 
                   FontSize="26" 
                   FontWeight="SemiBold"
                   Foreground="#263248"
                   Margin="0,0,0,35"/>

        <!-- Основная форма -->
        <StackPanel Grid.Row="1" Margin="0,0,0,40">

            <!-- Код и короткое название -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <StackPanel Width="400">
                    <TextBlock Text="Код федерации *" FontSize="14" Margin="0,0,0,6"/>
                    <TextBox Height="42" FontSize="15" x:Name="tbCode"/>
                </StackPanel>

                <StackPanel Width="400" Margin="40,0,0,0">
                    <TextBlock Text="Короткое наименование" FontSize="14" Margin="0,0,0,6"/>
                    <TextBox Height="42" FontSize="15" x:Name="tbShortName"/>
                </StackPanel>
            </StackPanel>

            <!-- Полное наименование -->
            <StackPanel Margin="0,0,0,20" Width="877">
                <TextBlock Text="Полное наименование *" FontSize="14" Margin="0,0,0,6"/>
                <TextBox Height="42" Width="841" FontSize="15" x:Name="tbFullName"   Margin="-36,0,0,0">
                    <TextBox.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform/>
                            <SkewTransform/>
                            <RotateTransform Angle="0.016"/>
                            <TranslateTransform/>
                        </TransformGroup>
                    </TextBox.RenderTransform>
                </TextBox>
            </StackPanel>

            <!-- Вид спорта, Статус, Состояние, Дата -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,25">
                <StackPanel Width="400">
                    <TextBlock Text="Вид спорта" FontSize="14" Margin="0,0,0,6"/>
                    <ComboBox Height="42" FontSize="15" x:Name="cbSportType"/>
                </StackPanel>

                <StackPanel Width="400" Margin="40,0,0,0">
                    <TextBlock Text="Статус аккредитации *" FontSize="14" Margin="0,0,0,6"/>
                    <ComboBox Height="42" FontSize="15" x:Name="cbAccreditationStatus"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,30">
                <StackPanel Width="400">
                    <TextBlock Text="Состояние федерации *" FontSize="14" Margin="0,0,0,6"/>
                    <ComboBox Height="42" FontSize="15" x:Name="cbFederationState"/>
                </StackPanel>

                <StackPanel Width="400" Margin="40,0,0,0">
                    <TextBlock Text="Дата окончания аккредитации" FontSize="14" Margin="0,0,0,6"/>
                    <DatePicker Height="42" FontSize="15" x:Name="dpAccreditationEnd"/>
                </StackPanel>
            </StackPanel>

            <!-- Блок контактной информации (увеличен) -->
            <GroupBox Header="Контактная информация" Padding="20" Margin="0,10,0,0">
                <StackPanel>
                    <TextBlock Text="Юридический адрес" FontSize="14" Margin="0,0,0,8"/>
                    <TextBox Height="42" FontSize="15" x:Name="tbLegalAddress" Margin="0,0,0,15"/>

                    <TextBlock Text="Почтовый адрес" FontSize="14" Margin="0,0,0,8"/>
                    <TextBox Height="42" FontSize="15" x:Name="tbPostalAddress" Margin="0,0,0,15"/>

                    <StackPanel Orientation="Horizontal">
                        <StackPanel Width="400">
                            <TextBlock Text="Телефон" FontSize="14" Margin="0,0,0,8"/>
                            <TextBox Height="42" FontSize="15" x:Name="tbPhone"/>
                        </StackPanel>
                        <StackPanel Width="400" Margin="40,0,0,0">
                            <TextBlock Text="E-mail" FontSize="14" Margin="0,0,0,8"/>
                            <TextBox Height="42" FontSize="15" x:Name="tbEmail"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </GroupBox>

        </StackPanel>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Отмена" 
                    Width="150" 
                    Height="50" 
                    Background="#E0E0E0"
                    Foreground="#263248"
                    FontSize="15"
                    Margin="0,0,20,0"
                    Click="BtnCancel_Click"/>

            <Button Content="Сохранить федерацию" 
                    Width="220" 
                    Height="50" 
                    Background="#263248"
                    Foreground="White"
                    FontSize="15"
                    FontWeight="Medium"
                    Click="BtnSave_Click"/>
        </StackPanel>
    </Grid>
</Window>