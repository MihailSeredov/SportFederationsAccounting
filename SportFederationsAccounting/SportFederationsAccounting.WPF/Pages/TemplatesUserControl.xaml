<UserControl x:Class="SportFederationsAccounting.WPF.Pages.TemplatesUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="650" 
             d:DesignWidth="1100"
             Background="#F8F9FA">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Margin="0,0,0,20">
            <TextBlock Text="Шаблоны документов" 
                       FontSize="28" 
                       FontWeight="SemiBold"
                       Foreground="#263248"
                       VerticalAlignment="Center"
                       Margin="0,0,10,0"/>

            <Button Content="+ Добавить новый шаблон"
                    DockPanel.Dock="Left"
                    Width="220"
                    Height="45"
                    FontSize="16"
                    Background="#263248"
                    Foreground="White"
                    HorizontalAlignment="Left"
                    Click="BtnAddTemplate_Click"/>
        </DockPanel>

        <DataGrid x:Name="dgTemplates"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  MouseDoubleClick="dgTemplates_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Название шаблона" 
                                    Binding="{Binding Name}" 
                                    Width="*" />
                <DataGridTextColumn Header="Файл" 
                                    Binding="{Binding OriginalFileName}" 
                                    Width="250"/>
                <DataGridTextColumn Header="Создан" 
                                    Binding="{Binding CreatedAt, StringFormat=dd.MM.yyyy HH:mm}" 
                                    Width="180"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>