<Window x:Class="SportFederationsAccounting.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Учёт спортивных федераций v0.2.6"
        Height="820"
        Width="1450"
        MinWidth="1100"
        MinHeight="650"
        WindowStartupLocation="CenterScreen"
        Background="#F8F9FA">

    <!-- Анимации панели -->
    <Window.Resources>
        <Storyboard x:Key="SlideDownAnimation">
            <DoubleAnimation Storyboard.TargetName="SpравочнаяПанель"
                             Storyboard.TargetProperty="Height"
                             From="0" To="260"
                             Duration="0:0:0.32"/>
        </Storyboard>
        <Storyboard x:Key="SlideUpAnimation">
            <DoubleAnimation Storyboard.TargetName="SpравочнаяПанель"
                             Storyboard.TargetProperty="Height"
                             From="260" To="0"
                             Duration="0:0:0.25"/>
        </Storyboard>

        <!-- Стиль для кнопок -->
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="19"/>
            <Setter Property="Height" Value="72"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#BEE6FD"/>
                    <Setter Property="Foreground" Value="#263248"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Верхнее меню -->
        <DockPanel Background="#263248" Height="72" VerticalAlignment="Top">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="30,0,0,0">
                <Button Content="Начальная страница" 
                        Width="180"
                        Height="72"
                        Margin="0,0,12,0"
                        Style="{StaticResource MenuButtonStyle}"
                        Click="BtnHome_Click"/>

                <Button x:Name="BtnSpравочная"
        Content="Справочная информация"
        Width="250"
        Height="72"
        Margin="0,0,12,0"
        Padding="12,0"
        Style="{StaticResource MenuButtonStyle}"
        Click="BtnSpравочная_Click"/>

                <Button Content="Оформление документации" 
                        Width="255"
                        Height="72"
                        Margin="0,0,12,0"
                        Style="{StaticResource MenuButtonStyle}"/>

                <Button Content="Отчёты" 
                        Width="135"
                        Height="72"
                        Margin="0,0,12,0"
                        Style="{StaticResource MenuButtonStyle}"/>
            </StackPanel>
        </DockPanel>

        <!-- Главный контейнер -->
        <ContentControl x:Name="MainContent" 
                        Margin="40,90,40,40" />

        <!-- Выдвижная панель -->
        <Grid x:Name="SpравочнаяПанель" 
              Background="#263248" 
              Height="0"             
              VerticalAlignment="Top" 
              Margin="0,72,0,0">
            <Border Background="White" 
                    CornerRadius="0,0,16,16" 
                    Margin="25"
                    Padding="10">
                <StackPanel>
                    <Button Content="📋 Федерации"
                    Height="52"
                    FontSize="16"
                    HorizontalAlignment="Stretch"
                    Margin="0,6"
                    Background="#F8F9FA"
                    Foreground="#263248"
                    BorderThickness="1"
                    BorderBrush="#E0E0E0"
                    Click="BtnFederations_Click"
                    />

                    <Button Content="🏅 Виды спорта"
                    Height="52"
                    FontSize="16"
                    HorizontalAlignment="Stretch"
                    Margin="0,6"
                    Background="#F8F9FA"
                    Foreground="#263248"
                    BorderThickness="1"
                    BorderBrush="#E0E0E0"
                    Click="BtnSportTypes_Click"
                    />

                    <Button Content="📄 Шаблоны Word"
                    Height="52"
                    FontSize="16"
                    HorizontalAlignment="Stretch"
                    Margin="0,6"
                    Background="#F8F9FA"
                    Foreground="#263248"
                    BorderThickness="1"
                    BorderBrush="#E0E0E0"
                    Click="BtnTemplates_Click"
                    />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>