<Window x:Class="SportFederationsAccounting.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Учёт спортивных федераций v0.1" 
        Height="780" 
        Width="1380"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA">

    <Grid>
        <!-- Верхнее меню -->
        <DockPanel Background="#2C3E50" Height="85" Margin="0,0,0,670">
            <TextBlock Text="Учёт спортивных федераций v0.1" 
                       Foreground="White" 
                       FontSize="24" 
                       FontWeight="SemiBold"
                       VerticalAlignment="Center" 
                       Margin="35,0,0,0"/>

            <StackPanel Orientation="Horizontal" 
                        HorizontalAlignment="Right" 
                        VerticalAlignment="Center" 
                        Margin="0,0,40,0">

                <Button Content="Начальная страница" 
                        Margin="15,0" 
                        Width="170"
                        Foreground="White" 
                        Background="#34495E" 
                        BorderThickness="0"
                        FontSize="14"
                        Click="BtnHome_Click"/>

                <Button Content="Справочная информация" 
                        Margin="15,0" 
                        Width="190"
                        Foreground="White" 
                        Background="#34495E" 
                        BorderThickness="0"
                        FontSize="14"
                        Click="BtnSpравочная_Click"/>

                <Button Content="Оформление документации" 
                        Margin="15,0" 
                        Width="210"
                        Foreground="White" 
                        Background="#34495E" 
                        BorderThickness="0"
                        FontSize="14"/>

                <Button Content="Отчёты" 
                        Margin="15,0" 
                        Width="130"
                        Foreground="White" 
                        Background="#34495E" 
                        BorderThickness="0"
                        FontSize="14"/>
            </StackPanel>
        </DockPanel>

        <!-- Основная область -->
        <Border Margin="35,110,35,35" 
                Background="White" 
                CornerRadius="12"
                Padding="50">
            <TextBlock Text="Главный дашборд системы учёта спортивных федераций" 
                       FontSize="27" 
                       HorizontalAlignment="Center" 
                       VerticalAlignment="Center"
                       Foreground="#2C3E50"
                       TextAlignment="Center"/>
        </Border>

        <!-- Выдвижная панель -->
        <Grid x:Name="SpравочнаяПанель" 
              Background="#2C3E50" 
              Height="320" 
              VerticalAlignment="Top" 
              Margin="0,85,0,0"
              Visibility="Collapsed">

            <Border Background="White" 
                    CornerRadius="0,0,12,12" 
                    Margin="20">
                <StackPanel Margin="30">
                    <TextBlock Text="Справочная информация" 
                               FontSize="20" 
                               FontWeight="Medium" 
                               Margin="0,0,0,25"/>

                    <Button Content="Федерации" 
                            Height="50" 
                            FontSize="16"
                            HorizontalAlignment="Left"
                            Margin="0,8"
                            Click="BtnFederations_Click"/>

                    <Button Content="Шаблоны Word" 
                            Height="50" 
                            FontSize="16"
                            HorizontalAlignment="Left"
                            Margin="0,8"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>