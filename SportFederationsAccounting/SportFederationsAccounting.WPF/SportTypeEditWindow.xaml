<Window x:Class="SportFederationsAccounting.WPF.SportTypeEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование вида спорта"
        Height="160"
        Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F8F9FA">
    <Window.Resources>


        <!-- Стиль для кнопок -->
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#263248"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Height" Value="72"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#BEE6FD"/>
                    <Setter Property="Foreground" Value="#263248"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20,20,20,5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Введите новое название вида спорта:" 
                   FontSize="14" 
                   Margin="0,0,0,10"/>

        <TextBox x:Name="tbName" 
                 Height="32" 
                 FontSize="15" 
                 Margin="0,0,0,20"
                 VerticalContentAlignment="Center"
                 />

        <!-- Кнопки внизу -->
        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right">

            <Button Content="Сохранить" 
                    Width="110" 
                    Height="35" 
                    Margin="0,0,10,0"
                    Click="BtnSave_Click"
                    Style="{StaticResource MenuButtonStyle}"/>

            <Button Content="Отмена" 
                    Width="90" 
                    Height="35"
                    Click="BtnCancel_Click"
                    Style="{StaticResource MenuButtonStyle}"/>
        </StackPanel>
    </Grid>
</Window>